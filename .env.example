# Copy to .env and fill in locally (never commit .env)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
LOCAL_AI_PORT=8787

# ElevenLabs (server-side only — used by Netlify Functions / local AI server)
ELEVENLABS_API_KEY=
